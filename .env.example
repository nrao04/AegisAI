# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aegis:aegis@localhost:5432/aegisai

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=incidents

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092

# ── AI (optional) ─────────────────────────────────────────────────────────────
# Claude API key — enables AI chatbot and runbook generation.
# Get yours at https://console.anthropic.com  Leave blank for rule-based fallback.
ANTHROPIC_API_KEY=

# ── Slack alerts (optional) ───────────────────────────────────────────────────
# Incoming webhook URL for HIGH/CRITICAL incident notifications.
# Create at https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=
