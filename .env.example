# AegisAI – copy to .env and adjust for your environment.
# When using Docker Compose, these are set in the compose file.

# PostgreSQL (required for backend and log-consumer)
DATABASE_URL=postgresql://aegis:aegis@localhost:5432/aegisai

# Elasticsearch (optional; search returns [] if unavailable)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=incidents

# Kafka (required for log producer and consumer)
KAFKA_BOOTSTRAP=127.0.0.1:9092

# Optional: API base URL for chatbot or frontend (default: http://localhost:8000)
# AEGIS_API_BASE=http://localhost:8000
